APP_NAME="SaaS Platform"
APP_ENV=development
APP_DEBUG=true
APP_PORT=3002

# Database (PostgreSQL for production)
DB_CONNECTION=memory
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=saas_starter
# DB_USERNAME=postgres
# DB_PASSWORD=secret

CACHE_DRIVER=memory
QUEUE_CONNECTION=sync
TENANCY_RESOLVER=subdomain

# JWT
JWT_SECRET=saas-starter-change-me-32-chars!!
JWT_EXPIRY=3600

# Auth - Social Login (replace with real values)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3002/auth/github/callback

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT=./storage

# Feature Flags
FLAGS_DRIVER=memory

# Billing (Stripe for production)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Mail
MAIL_DRIVER=memory
MAIL_FROM=noreply@saas.local

# Observability
OTEL_SERVICE_NAME=saas-starter
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# Redis (for production queue/cache)
REDIS_HOST=localhost
REDIS_PORT=6379
